# Course Co-Pilot Environment Configuration
# Copy this file to .env and fill in your values.
# On Railway, set the same variables in the service "Variables" tab (see RAILWAY.md).
# Additional runtime settings are documented in core/config.py.

# --- Required for transcript pipeline & research agent (see core/config.py) ---
OPENAI_API_KEY=

# Optional Anthropic (if used by your LLM paths)
# ANTHROPIC_API_KEY=

# Application (pydantic-settings: DEBUG, DEFAULT_CSV_PATH, etc.)
DEBUG=true

# Split deploy: browser origin(s) allowed to call the API (comma-separated). Leave unset for allow-all without cookies.
# CORS_ALLOWED_ORIGINS=https://your-frontend.up.railway.app,http://localhost:5173
# DEFAULT_CSV_PATH=data/syllabus_dataset.csv

# Matching (optional overrides)
# TOP_N_MATCHES=3
# SIMILARITY_THRESHOLD=0.3
# SOURCE_UNIVERSITY=Houston
# TARGET_UNIVERSITY=Duke

# Hugging Face cache (optional; helps repeated deploys if you use a volume)
# HF_HOME=/cache/hf
# TRANSFORMERS_CACHE=/cache/hf

# Server (Railway sets PORT automatically)
# PORT=8000
