# Vite — copy to .env.local (never commit secrets)
#
# Do NOT put OPENAI_API_KEY here. The browser cannot keep secrets; transcript
# evaluation calls the Python API, which reads OPENAI_API_KEY from the repo
# root .env (see courseCopilot/.env.example) or from your API host env
# (e.g. Railway Variables on the backend service).

# Supabase (optional until you wire auth; evaluation storage uses this when set)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# When API is on another origin (e.g. separate Railway service)
# VITE_API_URL=https://your-api.example.com
